rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Completely private to backend (Cloud Functions bypass rules)
    match /whatsapp_sessions/{session} {
      allow read, write: if false;
    }

    // Read-only for dashboard, written by backend
    match /meta/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /feedback/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Read & Write for the unauthenticated dashboard
    match /dumpPoints/{document=**} {
      allow read, write: if true;
    }
    match /reports/{document=**} {
      allow read, write: if true;
    }
  }
}
